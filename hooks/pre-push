#!/usr/bin/env bash
set -euo pipefail

# Load user tool paths (nvm, cargo, etc.) — hooks run with a stripped environment
[ -f "$HOME/.profile" ]   && . "$HOME/.profile"
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

cd "$(git rev-parse --show-toplevel)" || exit 1

echo "🧪 pre-push: running web tests (unit) ..."
(cd web && npm run test)

if [ "${SKIP_PLAYWRIGHT:-0}" = "1" ]; then
  echo "⏩ skipping Playwright (SKIP_PLAYWRIGHT=1)"
else
  echo "🎭 pre-push: Playwright smoke gate ..."
  (cd web && npm run test:e2e:smoke)
fi

echo "🦀 pre-push: cargo test ..."
(cd server && cargo test)

echo "✅ pre-push checks passed"
