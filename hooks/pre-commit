#!/usr/bin/env bash
# Pre-commit hook — runs fast checks before every commit.
# Customize the commands below for your tech stack.
set -euo pipefail

# Source profile for tool paths (nvm, cargo, etc.)
[ -f "$HOME/.profile" ] && source "$HOME/.profile" 2>/dev/null || true

echo "Running pre-commit checks..."

# --- Node/TypeScript (web) ---
cd web
npx eslint .
npx svelte-kit sync && npx svelte-check --tsconfig ./tsconfig.json
npm run test
cd ..

# --- Rust (server) ---
cd server
cargo fmt -- --check
cargo clippy -- -D warnings
cd ..

echo "Pre-commit checks passed."
