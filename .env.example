# Client (SvelteKit)
TASKSYNC_IMAGE_TAG=latest
WEB_HOST_PORT=5173
VITE_API_URL=http://localhost:3000
VITE_ALLOWED_HOSTS=localhost,127.0.0.1

# Server (Axum)
SERVER_HOST_PORT=3000
DATABASE_URL=sqlite://./data/tasksync.db
# REQUIRED: the server refuses to boot until this is set to a real value
# (not empty, not a known default like "tasksync-dev-secret" or "change-me").
JWT_SECRET=
RUST_LOG=info
# DEPRECATED (#047 closure): the shared DEV_LOGIN_PASSWORD fallback login has
# been removed — auth is hash-only. This variable is no longer read by the
# server; a stale value here is simply ignored. Owner/member passwords are
# now provisioned via first-run setup and the admin "reset password" flow.
# Safe to delete this line.
DEV_LOGIN_PASSWORD=
# Optional: comma-separated exact origins (scheme://host[:port], no path,
# no trailing slash) additionally allowed for CORS — e.g. your self-hosted
# PWA origin. The dev/Playwright/Capacitor origins (http://localhost:5173,
# http://localhost:4173, capacitor://localhost) are always allowed.
# CORS_ALLOWED_ORIGINS=https://tasks.example.com
TASKSYNC_DATA_SOURCE=tasksync_data

# Seed defaults
SEED_ADMIN_PASSWORD=tasksync
SEED_CONTRIB_PASSWORD=tasksync
